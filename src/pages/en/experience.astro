  <style>
    .page--experience {
      background: var(--color-bg-experience);
      min-height: 100vh;
      color: var(--color-ink);
    }
    .wrap {
      max-width: 1240px;
      margin: 0 auto;
      padding: 4.5rem 3.25rem;
    }
    h1 {
      margin: 0 0 2.5rem 0;
      font-family: var(--font-display);
      letter-spacing: -0.01em;
      font-size: 3rem;
    }
    h2 {
      margin: 0 0 0.75rem 0;
      font-size: 1.15rem;
      font-weight: 700;
    }
    p {
      margin: 0 0 2rem 0;
      color: var(--color-ink-80);
      max-width: 1100px;
