---
import Page from "../../layouts/Page.astro";
import WorkCard from "../../components/WorkCard.astro";
import { getCollection } from "astro:content";

const title = "Works";
const description = "Selected work";

const projects = (await getCollection("projects"))
  .slice()
  .sort((a, b) => (a.data.order ?? 9999) - (b.data.order ?? 9999));
---

<Page title={title} description={description}>
  <section class="page page--works">
    <div class="wrap">
      <h1>WORKS</h1>
      <div class="grid">
        {
          projects.map((p) => (
            <WorkCard
              title={p.data.title}
              subtitle={p.data.subtitle}
              description={p.data.description}
              image={p.data.image}
              buttonText={p.data.buttonText ?? "View"}
              url={p.data.url}
              repo={p.data.repo}
              featured={p.data.featured}
            />
          ))
        }
      </div>
    </div>
  </section>

  <style is:global>
    :root {
      --scrollbar-bg: var(--color-bg-works);
    }
  </style>
  <style>
    .page--works {
      background: var(--color-bg-works);
      min-height: 100vh;
      color: var(--color-ink);
    }
    .wrap {
      max-width: 1240px;
      margin: 0 auto;
      padding: 4.5rem 3.25rem;
    }
    h1 {
      margin: 0;
      font-family: var(--font-display);
      font-size: 4rem;
      letter-spacing: -0.01em;
    }
    .grid {
      margin-top: 2.5rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
      align-items: stretch;
    }

    @keyframes floatUp {
      from {
        opacity: 0;
        transform: translateY(36px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .grid :global(.card) {
      opacity: 0;
    }

    .grid :global(.card.is-visible) {
      animation: floatUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .hint {
      margin: 2rem 0 0 0;
      color: var(--color-ink-80);
    }
  </style>

  <script>
    document.addEventListener("astro:page-load", () => {
      const cards = document.querySelectorAll(".grid .card");

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              observer.unobserve(entry.target);
              const card = entry.target as HTMLElement;
              // Stagger by column position within the 3-column grid
              const index = Array.from(cards).indexOf(card);
              const col = index % 3;
              card.style.animationDelay = `${col * 80}ms`;
              card.classList.add("is-visible");
            }
          });
        },
        { threshold: 0.08 }
      );

      cards.forEach((card) => observer.observe(card));
    });
  </script>
</Page>
