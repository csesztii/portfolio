---
import Page from '../../layouts/Page.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getLocaleFromUrl, localePath, publicAsset } from '../../i18n/utils';

const title = 'Home';
const description = 'Portfolio home';

const locale = getLocaleFromUrl(Astro.url);
---

<Page title={title} description={description} showNav={false}>
  <section class="page page--home">
    <div class="lang">
      <a class="lang__item lang__item--active" href={localePath('/', 'en')}>→ English</a>
      <a class="lang__item" href={localePath('/', 'de')}>Deutsch</a>
      <a class="lang__item" href={localePath('/', 'hu')}>Magyar</a>
    </div>

    <div class="home">
      <section class="home__left">
        <img class="avatar" src={publicAsset('profile-placeholder.svg')} alt="" />
        <h1 class="name">Eszter Molnár</h1>
        <div class="role">M.Sc student in Computer Science</div>
        <a class="readcv" href={localePath('/cv', locale)}>Read my CV →</a>
        <button class="contactBtn" id="contact-open" type="button">CONTACT</button>
      </section>

      <section class="home__right">
        <div class="globe" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
            <path
              d="M3.5 12h17M12 3c2.5 2.7 4 5.9 4 9s-1.5 6.3-4 9c-2.5-2.7-4-5.9-4-9s1.5-6.3 4-9Z"
              stroke="currentColor"
              stroke-width="1.2"
            />
          </svg>
        </div>

        <div class="navBtns" id="home-nav">
          <a class="bigBtn bigBtn--exp" href={localePath('/experience', locale)}>EXPERIENCE</a>
          <a class="bigBtn bigBtn--works" href={localePath('/works', locale)}>WORKS</a>
          <a class="bigBtn bigBtn--cv" href={localePath('/cv', locale)}>CV</a>
        </div>

        <div class="contactPanel" id="contact-slot" hidden>
          <ContactForm title="CONTACT" />
        </div>
      </section>
    </div>
  </section>

  <script>
    const open = document.getElementById('contact-open');
    const slot = document.getElementById('contact-slot');
    const nav = document.getElementById('home-nav');
    if (open && slot) {
      open.addEventListener('click', () => {
        slot.hidden = !slot.hidden;
        if (nav) nav.hidden = !slot.hidden;
      });
    }
  </script>

  <style>
    .page--home {
      background: var(--color-bg-home);
      color: var(--color-white);
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 5.5rem 2.5rem 2.5rem;
    }
    .lang {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      background: var(--color-white);
      color: var(--color-ink);
      padding: 1.25rem 2.5rem;
      display: grid;
      gap: 0.5rem;
      text-align: center;
      font-size: 1.05rem;
    }
    .lang__item {
      text-decoration: none;
      color: inherit;
    }
    .lang__item--active {
      font-weight: 700;
      text-decoration: underline;
    }
    .home {
      width: min(1240px, 100%);
      height: 520px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-radius: 0;
    }
    .home__left {
      padding: 2.25rem 2.5rem;
      display: grid;
      align-content: start;
      gap: 1rem;
    }
    .avatar {
      width: 260px;
      height: 260px;
      object-fit: cover;
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.08);
    }
    .name {
      margin: 0;
      font-size: 2.5rem;
      letter-spacing: -0.02em;
      font-weight: 650;
    }
    .role {
      opacity: 0.9;
    }
    .readcv {
      color: inherit;
      width: max-content;
      opacity: 0.9;
    }
    .contactBtn {
      margin-top: 1.25rem;
      width: max-content;
      padding: 0.6rem 2.2rem;
      border-radius: 6px;
      border: 0;
      background: var(--color-bg-contact);
      color: var(--color-ink);
      font-weight: 700;
      letter-spacing: 0.02em;
      cursor: pointer;
    }

    .home__right {
      padding: 2.25rem 2.5rem;
      display: grid;
      align-content: start;
      gap: 2.25rem;
    }
    .globe {
      justify-self: start;
      opacity: 0.95;
    }
    .navBtns {
      display: grid;
      gap: 2.25rem;
    }
    .bigBtn {
      height: 92px;
      display: grid;
      place-items: center;
      text-decoration: none;
      color: inherit;
      border-radius: 4px;
      border: 2px solid currentColor;
      font-size: 2.4rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: rgba(255, 255, 255, 0.02);
      box-shadow: 0 0 0 rgba(0, 0, 0, 0);
    }
    .bigBtn--exp {
      color: #e0aaff;
      box-shadow: 0 0 16px rgba(224, 170, 255, 0.35);
    }
    .bigBtn--works {
      color: #90e0ef;
      box-shadow: 0 0 16px rgba(144, 224, 239, 0.35);
    }
    .bigBtn--cv {
      color: #ffd6a5;
      box-shadow: 0 0 16px rgba(255, 214, 165, 0.35);
    }
    .contactPanel {
      height: 100%;
    }
  </style>
</Page>

