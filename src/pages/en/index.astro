---
import Page from "../../layouts/Page.astro";
import ContactForm from "../../components/ContactForm.astro";
import { getLocaleFromUrl, localePath, publicAsset } from "../../i18n/utils";

const title = "Home";
const description = "Portfolio home";

const locale = getLocaleFromUrl(Astro.url);
---

<Page title={title} description={description} showNav={false}>
  <section class="page page--home">
    <div class="home">
      <section class="home__left">
        <div class="leftInner" id="left-content">
          <img class="avatar" src={publicAsset("media/profile.jpeg")} alt="" />
          <h1 class="name">Eszter Molnár</h1>
          <p class="intro">
            Introduction text goes here. Short, friendly, and to the point.
          </p>
          <a class="readcv" href={localePath("/cv", locale)}>Read my CV →</a>

          <div class="globeWrap">
            <div class="globe" aria-hidden="true">
              <svg width="42" height="42" viewBox="0 0 24 24" fill="none">
                <circle
                  cx="12"
                  cy="12"
                  r="9"
                  stroke="currentColor"
                  stroke-width="1.8"></circle>
                <path
                  d="M3.5 12h17M12 3c2.5 2.7 4 5.9 4 9s-1.5 6.3-4 9c-2.5-2.7-4-5.9-4-9s1.5-6.3 4-9Z"
                  stroke="currentColor"
                  stroke-width="1.2"></path>
              </svg>
            </div>

            <div class="lang" aria-label="Language">
              <a
                class="lang__item lang__item--active"
                href={localePath("/", "en")}>→ English</a
              >
              <a class="lang__item" href={localePath("/", "de")}>Deutsch</a>
              <a class="lang__item" href={localePath("/", "hu")}>Magyar</a>
            </div>
          </div>

          <button class="contactBtn" id="contact-open" type="button"
            >CONTACT</button
          >
        </div>

        <div class="contactOverlay" id="contact-slot" hidden>
          <button
            class="closeBtn"
            id="contact-close"
            type="button"
            aria-label="Close contact form"
          >
            ×
          </button>
          <ContactForm title="CONTACT" />
        </div>
      </section>

      <section class="home__right">
        <div class="navBtns" id="home-nav">
          <a class="bigBtn bigBtn--exp" href={localePath("/experience", locale)}
            >EXPERIENCE</a
          >
          <a class="bigBtn bigBtn--works" href={localePath("/works", locale)}
            >WORKS</a
          >
          <a class="bigBtn bigBtn--cv" href={localePath("/cv", locale)}>CV</a>
        </div>
      </section>
    </div>
  </section>

  <script>
    const open = document.getElementById("contact-open");
    const slot = document.getElementById("contact-slot");
    const close = document.getElementById("contact-close");
    const nav = document.getElementById("home-nav");
    if (open && slot) {
      open.addEventListener("click", () => {
        slot.hidden = false;
        if (nav) nav.hidden = true;
        document.documentElement.style.overflow = "hidden";
      });
    }
    if (close && slot) {
      close.addEventListener("click", () => {
        slot.hidden = true;
        if (nav) nav.hidden = false;
        document.documentElement.style.overflow = "";
      });
    }
  </script>

  <style>
    .page--home {
      background: var(--color-bg-home);
      color: var(--color-white);
      min-height: 100vh;
      display: grid;
      overflow: hidden; /* no visible scrollbars on desktop layout */
    }
    .home {
      width: 100%;
      min-height: 100vh;
      display: grid;
      grid-template-columns: 50% 50%;
    }
    .home__left {
      position: relative;
      padding: 4rem 4.5rem;
      display: grid;
      align-content: start;
      overflow: hidden;
    }
    .leftInner {
      display: grid;
      align-content: start;
      gap: 1rem;
    }
    .avatar {
      width: 260px;
      height: 260px;
      object-fit: cover;
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.08);
    }
    .name {
      margin: 0;
      font-size: 2.5rem;
      letter-spacing: -0.02em;
      font-weight: 500;
    }
    .intro {
      margin: 0;
      opacity: 0.92;
      max-width: 28rem;
    }
    .readcv {
      color: inherit;
      width: max-content;
      opacity: 0.9;
      text-decoration: underline;
      text-underline-offset: 6px;
    }

    .globeWrap {
      position: absolute;
      top: 2.25rem;
      right: 2.25rem; /* close to page horizontal middle (left column edge) */
      width: max-content;
    }
    .globe {
      width: max-content;
      opacity: 0.95;
      cursor: default;
    }
    .lang {
      position: absolute;
      top: 0px;
      left: -100px;
      background: var(--color-white);
      color: var(--color-ink);
      padding: 1.25rem 2.5rem;
      display: none;
      gap: 0.5rem;
      text-align: center;
      font-size: 1.05rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
      min-width: 9.375rem;
      max-width: 18.75rem;
    }
    .lang__item {
      text-decoration: none;
      color: inherit;
    }
    .lang__item--active {
      font-weight: 700;
      text-decoration: underline;
      text-underline-offset: 6px;
    }
    .globeWrap:hover .lang {
      display: grid;
    }

    .contactBtn {
      margin-top: 1.25rem;
      width: max-content;
      padding: 0.6rem 2.2rem;
      border-radius: 6px;
      border: 0;
      background: var(--color-bg-contact);
      color: var(--color-ink);
      font-weight: 500;
      letter-spacing: 0.02em;
      cursor: pointer;
    }

    .contactOverlay {
      position: absolute;
      inset: 0;
      z-index: 5;
      overflow: auto;
    }
    .closeBtn {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      z-index: 6;
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 2px solid rgba(34, 34, 59, 0.55);
      background: rgba(255, 255, 255, 0.35);
      color: var(--color-ink);
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
    }

    .home__right {
      padding: 4rem 4.5rem;
      display: flex;
      flex-direction: column;
    }
    .navBtns {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-evenly;
      gap: 0;
    }
    .bigBtn {
      height: 25%;
      display: grid;
      place-items: center;
      text-decoration: none;
      color: inherit;
      border-radius: 15px;
      border: 2px solid currentColor;
      font-size: 3.5rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: rgba(255, 255, 255, 0.02);
      box-shadow: 0 0 0 rgba(0, 0, 0, 0);
    }
    .bigBtn--exp {
      color: #e0aaff;
      box-shadow: 0 0 16px rgba(224, 170, 255, 0.35);
    }
    .bigBtn--works {
      color: #90e0ef;
      box-shadow: 0 0 16px rgba(144, 224, 239, 0.35);
    }
    .bigBtn--cv {
      color: #ffd6a5;
      box-shadow: 0 0 16px rgba(255, 214, 165, 0.35);
    }
  </style>
</Page>
