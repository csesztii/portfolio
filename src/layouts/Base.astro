---
import '../styles/global.css';

import { ClientRouter } from 'astro:transitions';
import type { Locale } from '../i18n/utils';
import { alternatePathname, localePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  locale: string;
  canonical: string;
}

const { title, description, locale, canonical } = Astro.props;

const hrefLocales: Locale[] = ['en', 'hu', 'de'];

function absoluteHref(pathnameLike: string) {
  if (pathnameLike.startsWith('http')) return pathnameLike;

  /**
   * `alternatePathname` returns a pathname (with GitHub Pages `base` when configured).
   * Resolve against the configured `site`, or fall back to the current request URL.
   */
  return new URL(pathnameLike, Astro.site ?? Astro.url).href;
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
      rel="stylesheet"
    />

    {hrefLocales.map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={absoluteHref(alternatePathname(Astro.url, l))}
      />
    ))}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={locale} />
    <meta property="og:type" content="website" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Eszter Molnár',
        url: Astro.site ? new URL(localePath('/', 'en'), Astro.site).href : Astro.url.href,
        sameAs: ['https://linkedin.com/in/yourprofile', 'https://github.com/yourusername'],
      })}
    />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only">Skip to content</a>
    <slot />
    <script is:inline>
      document.addEventListener('mousemove', (e) => {
        document.body.style.setProperty('--mouse-x', `${e.clientX}px`);
        document.body.style.setProperty('--mouse-y', `${e.clientY}px`);
      });
    </script>
  </body>
</html>

