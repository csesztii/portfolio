---
import { publicAsset } from "../i18n/utils";

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  image: string;
  buttonText?: string;
  url?: string;
  repo?: string;
  featured?: boolean;
}

const {
  title,
  subtitle,
  description,
  image,
  buttonText = "View",
  url,
  repo,
  featured = false,
} = Astro.props;

const normalizedImage =
  image.startsWith("http://") ||
  image.startsWith("https://") ||
  image.startsWith("data:")
    ? image
    : publicAsset(image.replace(/^\/+/, ""));

const href = url ?? repo ?? "#";
---

<article class={`card ${featured ? "card--featured" : ""}`}>
  <div class="card__inner">
    <div class="card__header">
      <h3 class="card__title">{title}</h3>
      {subtitle && <p class="card__subtitle">{subtitle}</p>}
    </div>

    <div class="card__body">
      <div class="card__media">
        <img class="card__img" src={normalizedImage} alt="" loading="lazy" />
      </div>
      <p class="card__desc">{description}</p>
    </div>

    <div class="card__actions">
      {
        url && (
          <a class="card__cta" href={url} target="_blank">
            {buttonText}
          </a>
        )
      }
      {
        repo && (
          <a class="card__cta" href={repo} target="_blank">
            SEE CODE
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .card {
    border-radius: 10px;
    border: 2px solid var(--color-ink);
    background: transparent;
    color: var(--color-ink);
    overflow: hidden;
  }
  .card--featured {
    grid-column: span 2;
    background: var(--color-ink);
    color: var(--color-bg-works);
    border-color: var(--color-ink);
  }
  .card__inner {
    height: 100%;
    padding: 2rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .card--featured .card__inner {
    gap: 1.5rem;
  }

  .card__header {
    display: grid;
    gap: 0.25rem;
  }
  .card__body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex-grow: 1;
  }
  .card--featured .card__body {
    flex-direction: row-reverse;
    align-items: flex-start;
  }

  .card__media {
    height: 180px;
    border-radius: 6px;
    overflow: hidden;
    background: transparent;
  }
  .card--featured .card__media {
    flex: 0 0 45%;
    max-width: 400px;
    height: 260px;
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center;
  }
  .card--featured .card__img {
    object-position: center;
  }

  .card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 650;
    line-height: 1.1;
  }
  .card--featured .card__title {
    font-size: 2.2rem;
  }
  .card__subtitle {
    margin: 0;
    font-size: 1.5rem;
    color: inherit;
    font-weight: 300;
  }
  .card__desc {
    margin: 0;
    color: inherit;
    min-height: 2.2em;
    font-size: 1.05rem;
  }
  .card--featured .card__desc {
    flex: 1;
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: auto;
    padding-top: 1rem;
  }
  .card__cta {
    border-radius: 6px;
    padding: 0.6rem 2rem;
    border: 2px solid var(--color-ink);
    background: var(--color-ink);
    color: var(--color-bg-works);
    text-decoration: none;
    letter-spacing: 0.02em;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }
  .card__cta:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }
  .card--featured .card__cta {
    border-color: var(--color-bg-works);
    background: var(--color-bg-works);
    color: var(--color-ink);
  }
</style>
