---
import { publicAsset } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  image: string;
  buttonText?: string;
  url?: string;
  repo?: string;
}

const {
  title,
  description,
  image,
  buttonText = "View",
  url,
  repo,
} = Astro.props;

const normalizedImage =
  image.startsWith("http://") ||
  image.startsWith("https://") ||
  image.startsWith("data:")
    ? image
    : publicAsset(image.replace(/^\/+/, ""));

const href = url ?? repo ?? "#";
---

<article class="card">
  <div class="card__inner">
    <h3 class="card__title">{title}</h3>
    <div class="card__media">
      <img class="card__img" src={normalizedImage} alt="" loading="lazy" />
    </div>
    <p class="card__desc">{description}</p>
    <a class="card__cta" href={href} target="_blank">{buttonText}</a>
  </div>
</article>

<style>
  .card {
    border-radius: 10px;
    border: 2px solid var(--color-ink);
    background: transparent;
    overflow: hidden;
  }
  .card__inner {
    height: 100%;
    padding: 2rem 1.6rem;
    display: grid;
    align-content: start;
    gap: 1.25rem;
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card__media {
    height: 170px;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.25);
  }
  .card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 650;
  }
  .card__desc {
    margin: 0;
    color: var(--color-ink-80);
    min-height: 2.2em;
  }
  .card__cta {
    width: max-content;
    justify-self: center;
    border-radius: 6px;
    padding: 0.55rem 2.5rem;
    border: 0;
    background: var(--color-ink);
    color: var(--color-white);
    text-decoration: none;
    letter-spacing: 0.02em;
    font-weight: 600;
  }
</style>
