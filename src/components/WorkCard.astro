---
import { publicAsset } from "../i18n/utils";

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  image: string;
  buttonText?: string;
  url?: string;
  repo?: string;
  featured?: boolean;
}

const {
  title,
  subtitle,
  description,
  image,
  buttonText = "View",
  url,
  repo,
  featured = false,
} = Astro.props;

const normalizedImage =
  image.startsWith("http://") ||
  image.startsWith("https://") ||
  image.startsWith("data:")
    ? image
    : publicAsset(image.replace(/^\/+/, ""));

const href = url ?? repo ?? "#";
---

<article class={`card ${featured ? "card--featured" : ""}`}>
  <div class="card__inner">
    <div class="card__header">
      <h3 class="card__title">{title}</h3>
      {subtitle && <p class="card__subtitle">{subtitle}</p>}
    </div>

    <div class="card__body">
      <div class="card__media">
        <img
          class="card__img"
          src={normalizedImage}
          alt=""
          loading="lazy"
          decoding="async"
          data-card-img
        />
      </div>
      <p class="card__desc">{description}</p>
    </div>

    <div class="card__actions">
      {
        url && (
          <a class="card__cta" href={url} target="_blank">
            {buttonText}
          </a>
        )
      }
      {
        repo && (
          <a class="card__cta" href={repo} target="_blank">
            SEE CODE
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .card {
    border-radius: 10px;
    /* border: 2px solid var(--color-ink); */
    border: 2px solid #62b5c4;
    background: transparent;
    color: var(--color-ink);
    overflow: hidden;
  }

  .card:hover {
    border: 2px solid var(--color-ink);
    box-shadow: 0 0 16px rgba(34, 34, 59, 0.29);
  }

  .card--featured {
    grid-column: span 2;
    background: var(--color-ink);
    color: var(--color-bg-works);
    border-color: var(--color-ink);
  }
  .card__inner {
    height: 100%;
    padding: 2rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .card--featured .card__inner {
    gap: 1.5rem;
  }

  .card__header {
    display: grid;
    gap: 0.25rem;
  }
  .card__body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex-grow: 1;
  }
  .card--featured .card__body {
    flex-direction: row-reverse;
    align-items: flex-start;
  }

  /* Skeleton shimmer while image loads */
  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
  .card__media {
    height: 180px;
    border-radius: 6px;
    overflow: hidden;
    background: linear-gradient(
      90deg,
      rgba(34, 34, 59, 0.08) 25%,
      rgba(34, 34, 59, 0.16) 50%,
      rgba(34, 34, 59, 0.08) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.4s ease infinite;
  }
  /* Stop shimmer once img has loaded (class toggled by script) */
  .card__media.is-loaded {
    background: transparent;
    animation: none;
  }
  .card--featured .card__media {
    flex: 0 0 45%;
    max-width: 400px;
    height: 260px;
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center;
    /* Start invisible; fade in once loaded */
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .card__img.is-loaded {
    opacity: 1;
  }
  .card--featured .card__img {
    object-position: center;
  }

  .card__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    line-height: 1.1;
    font-size: 2.2rem;
  }

  .card__subtitle {
    margin: 0;
    font-size: 1.5rem;
    color: inherit;
    line-height: 1.3;
    font-weight: 300;
  }
  .card__desc {
    margin: 0;
    color: inherit;
    min-height: 2.2em;
    font-size: 1.15rem;
    line-height: 1.6;
  }
  .card--featured .card__desc {
    flex: 1;
  }

  .card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: auto;
    padding-top: 1rem;
  }
  .card__cta {
    border-radius: 6px;
    padding: 0.6rem 2rem;
    border: 2px solid var(--color-ink);
    background: var(--color-ink);
    color: var(--color-bg-works);
    text-decoration: none;
    letter-spacing: 0.02em;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }
  .card__cta:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }
  .card--featured .card__cta {
    border-color: var(--color-bg-works);
    background: var(--color-bg-works);
    color: var(--color-ink);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("img[data-card-img]").forEach((img) => {
      const el = img as HTMLImageElement;
      const media = el.closest(".card__media") as HTMLElement | null;

      const reveal = () => {
        el.classList.add("is-loaded");
        media?.classList.add("is-loaded");
      };

      if (el.complete && el.naturalWidth > 0) {
        // Already cached — reveal immediately
        reveal();
      } else {
        el.addEventListener("load", reveal, { once: true });
        // If it errors (broken src) just show the shimmer-less container
        el.addEventListener("error", () => media?.classList.add("is-loaded"), {
          once: true,
        });
      }
    });
  });
</script>
