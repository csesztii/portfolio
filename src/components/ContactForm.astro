---
interface Props {
  title?: string;
}

const { title = "Contact" } = Astro.props;
---

<section aria-label={title} class="panel">
  <h2 class="panel__title">{title}</h2>
  <div class="meta">
    <div class="meta__line"><p>mol.eszter04@gmail.com</p></div>
    <div class="meta__line"><p>+36 30 911 7060</p></div>
    <a
      class="meta__link"
      href="https://www.linkedin.com/in/esztermolnar0420"
      aria-label="LinkedIn">Linkedin →</a
    >
  </div>
  <div id="success-box" class="success-box">Message successfully sent</div>
  <form
    class="form"
    id="contact-form"
    method="post"
    action="https://formsubmit.co/mol.eszter04@gmail.com"
  >
    <input type="hidden" name="_captcha" value="false" />
    <input type="text" name="_honey" style="display:none" />
    <div class="row">
      <label class="field">
        <span class="field__label">First Name</span>
        <input
          class="field__control"
          name="firstName"
          autocomplete="given-name"
          placeholder="First Name"
          required
          maxlength="50"
        />
      </label>
      <label class="field">
        <span class="field__label">Last Name</span>
        <input
          class="field__control"
          name="lastName"
          autocomplete="family-name"
          placeholder="Last Name"
          required
          maxlength="50"
        />
      </label>
    </div>

    <label class="field">
      <span class="field__label">E-mail Address</span>
      <input
        class="field__control"
        type="email"
        name="email"
        placeholder="E-mail Address"
        required
        maxlength="100"
      />
    </label>

    <label class="field">
      <span class="field__label">Message</span>
      <textarea
        class="field__control field__control--textarea"
        name="message"
        rows={9}
        placeholder="Message"
        required
        maxlength="2000"></textarea>
    </label>

    <button class="button button--primary" type="submit">SEND</button>
  </form>
</section>

<style>
  .panel {
    border: 0;
    border-radius: 0;
    padding: var(--space-16);
    background: var(--color-bg-contact);
    color: var(--color-ink);
    min-height: 100vh;
  }
  .panel__title {
    margin: 0 0 var(--space-8) 0;
    font-family: var(--font-display);
    font-size: 3rem;
    letter-spacing: -0.02em;
    font-weight: 500;
  }
  .meta {
    display: grid;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }
  .meta__link {
    color: inherit;
    text-decoration: underline;
    width: max-content;
  }
  .meta__line {
    color: inherit;
  }
  .form {
    display: grid;
    gap: var(--space-4);
    max-width: 720px;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .field {
    display: grid;
    gap: var(--space-2);
  }
  .field__label {
    display: none;
  }
  .field__control {
    width: 100%;
    border: 2px solid var(--color-gray-400, #888888);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.8rem;
    background: rgb(255, 255, 255);
    color: inherit;
  }
  .field__control--textarea {
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
    resize: none;
    min-height: 180px;
  }
  .field__control:focus,
  .field__control:active {
    outline: none;
    border-color: var(--color-ink);
  }
  .field__control::placeholder {
    color: var(--color-gray-400, #888888);
    opacity: 1;
  }
  .button {
    border-radius: var(--radius-sm);
    padding: 0.55rem 3rem;
    border: 0;
    background: var(--color-ink);
    color: var(--color-white);
    width: max-content;
    justify-self: end;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .button--primary {
    background: var(--color-ink);
  }
  .success-box {
    display: none;
    margin-bottom: var(--space-4);
    padding: var(--space-4);
    background: #7ed06d;
    color: var(--color-ink);
    border: 1px solid #c1e6c1;
    border-radius: var(--radius-sm);
    font-weight: 500;
    text-align: center;
    font-size: 1.2rem;
  }
</style>

<style is:global>
  /* Custom Scrollbar for the Contact Form & Textarea */
  .contactOverlay::-webkit-scrollbar,
  .contactOverlay *::-webkit-scrollbar,
  .field__control--textarea::-webkit-scrollbar {
    width: 24px;
    height: 24px;
  }
  .contactOverlay::-webkit-scrollbar-track,
  .contactOverlay *::-webkit-scrollbar-track,
  .field__control--textarea::-webkit-scrollbar-track {
    background: var(--color-bg-contact);
  }
  .contactOverlay::-webkit-scrollbar-thumb,
  .contactOverlay *::-webkit-scrollbar-thumb,
  .field__control--textarea::-webkit-scrollbar-thumb {
    background-color: var(--color-ink);
    border-radius: 999px;
    border: 5px solid var(--color-bg-contact);
    background-clip: padding-box;
  }
  .contactOverlay::-webkit-scrollbar-button,
  .contactOverlay *::-webkit-scrollbar-button,
  .field__control--textarea::-webkit-scrollbar-button {
    display: none;
  }
  
  /* Firefox standard scrollbar properties (Hidden from Chrome 121+) */
  @-moz-document url-prefix() {
    .contactOverlay,
    .contactOverlay *,
    .field__control--textarea {
      scrollbar-color: var(--color-ink) var(--color-bg-contact);
      scrollbar-width: auto;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const successBox = document.getElementById("success-box");

    if (form && successBox) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const submitBtn = form.querySelector(
          'button[type="submit"]',
        ) as HTMLButtonElement;
        if (submitBtn) {
          submitBtn.textContent = "SENDING...";
          submitBtn.disabled = true;
        }

        try {
          const response = await fetch(
            "https://formsubmit.co/ajax/mol.eszter04@gmail.com",
            {
              method: "POST",
              body: formData,
              headers: {
                Accept: "application/json",
              },
            },
          );

          if (response.ok) {
            successBox.style.display = "block";
            form.reset();
            setTimeout(() => {
              successBox.style.display = "none";
            }, 5000);
          } else {
            console.error("Form submission failed", response.status);
          }
        } catch (error) {
          console.error("Form submission error", error);
        } finally {
          if (submitBtn) {
            submitBtn.textContent = "SEND";
            submitBtn.disabled = false;
          }
        }
      });
    }
  });
</script>
